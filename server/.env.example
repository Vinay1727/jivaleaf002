MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/plant?retryWrites=true&w=majority
JWT_SECRET=please-change-this-secret
PORT=4000
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
ADMIN_SECRET=change_this_to_create_admin

# Optional: SMTP settings used to send OTP emails.
# If omitted the server will create a Nodemailer test account (ethereal.email) and log preview URLs.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Your Store <no-reply@example.com>"

# Example for SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
